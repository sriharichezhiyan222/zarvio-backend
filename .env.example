# Example environment variables (do not store real secrets here)

OPENAI_API_KEY=your_openai_api_key

# Supabase project configuration
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_key

# Supabase JWT secret (Project Settings -> API -> JWT Secret)
SUPABASE_JWT_SECRET=your_jwt_secret

# Apollo API key (for /api/find-leads)
APOLLO_API_KEY=your_apollo_api_key

# PostgreSQL / Supabase database connection URL
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/zarvio

# Optional additional service keys
ANTHROPIC_API_KEY=your_anthropic_api_key
HUBSPOT_API_KEY=your_hubspot_api_key
RESEND_API_KEY=your_resend_api_key
NEWS_API_KEY=your_newsapi_api_key
BUILTWITH_API_KEY=your_builtwith_api_key
SNOVIO_CLIENT_ID=your_snovio_client_id
SNOVIO_CLIENT_SECRET=your_snovio_client_secret
EXPLORIUM_API_KEY=your_explorium_api_key
POSTHOG_API_KEY=your_posthog_api_key
POSTHOG_HOST=https://app.posthog.com
STRIPE_SECRET_KEY=your_stripe_secret_key
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
FRONTEND_URL=https://your-frontend.app


