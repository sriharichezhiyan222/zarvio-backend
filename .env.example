# Example environment variables (do not store real secrets here)

OPENAI_API_KEY=your_openai_api_key

# Supabase project configuration
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_key

# Supabase JWT secret (Project Settings -> API -> JWT Secret)
SUPABASE_JWT_SECRET=your_jwt_secret

# PostgreSQL / Supabase database connection URL
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/zarvio


